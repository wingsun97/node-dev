FROM node:24-slim

# 安装常用工具
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    bash \
    openssh-client \
    vim \
    nano \
    ca-certificates \
    unzip \
    lsb-release \
    gnupg \
    protobuf-compiler \
    build-essential \
    pkg-config \
    iputils-ping \
 && rm -rf /var/lib/apt/lists/*

# 全局安装 pnpm
RUN npm install -g pnpm

# 安装 Go
ENV GO_VERSION=1.26.1
RUN curl -fsSL https://go.dev/dl/go${GO_VERSION}.linux-amd64.tar.gz -o /tmp/go.tgz \
 && rm -rf /usr/local/go \
 && tar -C /usr/local -xzf /tmp/go.tgz \
 && rm /tmp/go.tgz

# gRPC plugins
RUN /usr/local/go/bin/go install google.golang.org/protobuf/cmd/protoc-gen-go@latest \
 && /usr/local/go/bin/go install google.golang.org/grpc/cmd/protoc-gen-go-grpc@latest

# 设置工作目录
WORKDIR /app

# 更改工作目录所有权
RUN chown -R node:node /app

# 默认 shell 设置为 bash
SHELL ["/bin/bash", "-c"]

# 设置默认用户为 node
USER node

# 初始化 pnpm 并设置缓存路径
ENV PNPM_HOME="/home/node/.local/share/pnpm"

# 配置 Go 环境变量
ENV GOPATH=/home/node/go

ENV PATH="/usr/local/go/bin:$GOPATH/bin:$PNPM_HOME:$PATH"

# 启动命令（可根据需要自定义）
CMD ["tail", "-f", "/dev/null"]